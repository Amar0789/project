pipeline {
    agent any

    environment {
        ENV_TYPE = 'prod'
    }

    tools{
        jdk 'JDK-17'
    }

    stages {
        stage('parallel'){
            perallel{
                stage('one'){
                    steps{
                        echo "I am from parallel One"
                    }
                }
                stage('two'){
                    steps{
                        echo "I am from parallel Two"
                    }
                }
            }
        }
    }
}