pipeline{
    agent any
    environment{
        env_type = 'prod'
    }
    stages{
        stage('one'){
            steps{
                echo "I am from stage one"
            }
        }
        stage('Approval'){
            steps{
                input{
                    message "Do you want to approve this build"
                    ok "yes, Deploy"
                }
            }
        }

        stage('Three'){
            when{
                environment name: 'env_type' , value: 'prod'
            }
            steps{
                echo "It will only be printed when environment is prod"
            }
        }
    }
}