pipeline{
    agent any
    environment{
        env_type = 'prod'
    }
    stages{
        stage('one'){
            steps{
                echo "I am from stage one"
            }
        }
        stage('two'){
            steps{
                echo "I am from stage 2"
            }
        }
        stage('Three'){
            when{
                environment name = env_type , value = 'prod'
            }
        }
    }
}