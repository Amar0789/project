pipeline {
    agent any

    environment {
        ENV_TYPE = 'prod'
    }

    stages {

        stage('Build') {
            steps {
                echo "I am from stage one"
            }
        }

        stage('Approval') {
            agent none
            steps {
                input {
                    message "Do you want to approve this build?"
                    ok "Yes, Deploy"
                }
            }
        }

        stage('Deploy') {
            when {
                environment name: 'ENV_TYPE', value: 'prod'
            }
            steps {
                echo "Deploying to production"
            }
        }
    }
}