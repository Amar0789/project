pipeline {
    agent any

    environment {
        ENV_TYPE = 'prod'
    }


    stages {
        stage('parallel'){
            parallel{
                stage('one'){
                    steps{
                        echo "I am from parallel One"
                    }
                }
                stage('two'){
                    steps{
                        echo "I am from parallel Two"
                    }
                }
            }
        }
    }
}