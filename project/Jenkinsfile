pipeline {
    agent any

    environment {
        ENV_TYPE = 'prod'
    }


    stages {
        stage('parallel'){
            parallel{
                stage('one'){
                    steps{
                        echo "I am from parallel One"
                    }
                }
                stage('two'){
                    steps{
                        echo "I am from parallel Two"
                    }
                }
            }
        }
        stage('script'){
            steps{
                script{
                    def x = 5
                    if (x == 5) {
                        echo "The value of x is 5"
                    }
                }
            }
        }
    }
}